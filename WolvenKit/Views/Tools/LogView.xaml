<reactiveUi:ReactiveUserControl
    x:Class="WolvenKit.Views.Tools.LogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:WolvenKit.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:reactiveUi="http://reactiveui.net"
    xmlns:sfgrid="clr-namespace:Syncfusion.UI.Xaml.Grid;assembly=Syncfusion.SfGrid.WPF"
    xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
    xmlns:tools="clr-namespace:WolvenKit.App.ViewModels.Tools;assembly=WolvenKit.App"
    xmlns:tools1="clr-namespace:WolvenKit.Views.Tools"
    xmlns:templates="clr-namespace:WolvenKit.Views.Templates"
    x:Name="uc"
    d:DataContext="{d:DesignInstance Type=tools:LogViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:TypeArguments="tools:LogViewModel"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <hc:ThemeResources RequestedTheme="Dark" />
                <hc:Theme />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="LogViewGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid.Resources>
            <converters:NullVisibilityConverter x:Key="NullVisibilityConverter" />
        </Grid.Resources>

        <Grid x:Name="ScriptShortcutGrid"
              Grid.Row="0"
              Grid.Column="0"
              Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" MinWidth="{DynamicResource WolvenKitLogScriptMinWidth}" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="UpdateButton"
                Grid.Column="0"
                Height="Auto"
                Margin="{DynamicResource WolvenKitMarginTinyRight}"
                HorizontalAlignment="Right"
                ToolTip="Update scripts"
                Command="{Binding UpdateScriptsCommand}">
                <templates:IconTemplateView
                    IconPack="Material"
                    Kind="Refresh"
                    Size="{DynamicResource WolvenKitTinyIconSize}"
                    Foreground="White" />
            </Button>

            <ComboBox
                x:Name="ScriptFileComboBox"
                Grid.Column="1"
                Margin="{DynamicResource WolvenKitMarginTinyRight}"
                ToolTip="Select script"
                IsEditable="False"
                IsReadOnly="True"
                ItemsSource="{Binding ScriptFiles.View}"
                SelectedItem="{Binding SelectedScriptFile}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical"
                                    ToolTip="{Binding HoverInfo}">
                            <TextBlock Text="{Binding Name}" />
                            <TextBlock x:Name="Info"
                                       Text="{Binding SelectInfo}" />
                        </StackPanel>

                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ComboBoxItem}}"
                                         Value="{x:Null}">
                                <Setter TargetName="Info"
                                        Property="Visibility"
                                        Value="Collapsed" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
                
                <ComboBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border BorderBrush="White"
                                        BorderThickness="0,0,0,1"
                                        Padding="15,0,0,7">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="{DynamicResource WolvenKitBodyFontSize}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ComboBox.GroupStyle>
            </ComboBox>

            <Button
                x:Name="RunButton"
                Grid.Column="2"
                Height="Auto"
                Margin="{DynamicResource WolvenKitMarginTinyRight}"
                ToolTip="Reload and run"
                Command="{Binding RunScriptCommand}"
                IsEnabled="{Binding CanRunScript}">
                <templates:IconTemplateView
                    IconPack="Material"
                    Kind="Play"
                    Size="{DynamicResource WolvenKitTinyIconSize}"
                    Foreground="{StaticResource WolvenKitGreen}" />
            </Button>
        </Grid>

        <ItemsControl
            Grid.Row="1"
            Grid.Column="0"
            ItemsSource="{Binding ElementName=uc, Path=LogEntries}"
            ScrollViewer.CanContentScroll="True"
            VirtualizingPanel.ScrollUnit="Pixel"
            KeyUp="LogView_OnKeyUp"
            VirtualizingStackPanel.VirtualizationMode="Recycling">
            <ItemsControl.Resources>
                <DataTemplate DataType="{x:Type tools1:LogEntry}">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid.Style>
                            <Style TargetType="{x:Type Grid}">
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Opacity="0.10" Color="Gray" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <TextBox
                            Grid.Column="0"
                            MinHeight="{DynamicResource WolvenKitLogLineMinHeight}"
                            Padding="0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            FontFamily="Consolas"
                            FontSize="{DynamicResource WolvenKitSubTitleFontSize}"
                            Foreground="{Binding TextColor}"
                            IsReadOnly="True"
                            Text="{Binding Path=Message}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Grid.Column="1"
                            Padding="0,0,5,0"
                            Visibility="{Binding Uri, Converter={StaticResource NullVisibilityConverter}}">
                            <Hyperlink
                                NavigateUri="{Binding Uri}"
                                RequestNavigate="Hyperlink_OnRequestNavigate"
                                ToolTip="{Binding Uri}">
                                More Info
                            </Hyperlink>
                        </TextBlock>

                        <Button
                            Grid.Column="2"
                            Padding="0,0,12,0"
                            VerticalAlignment="Center"
                            BorderThickness="1"
                            Click="CopyLine_OnClick"
                            Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                            Tag="{Binding Message}"
                            ToolTip="Copy line">

                            <templates:IconTemplateView
                                IconPack="Octicons"
                                Kind="Clippy"
                                Size="{DynamicResource WolvenKitMicroIconSize}"
                                Foreground="White" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ItemsControl.Resources>

            <ItemsControl.Template>
                <ControlTemplate>
                    <ScrollViewer
                        Background="#131313"
                        Loaded="ScrollViewer_Loaded"
                        VerticalScrollBarVisibility="Disabled">
                        <ItemsPresenter />
                    </ScrollViewer>
                </ControlTemplate>
            </ItemsControl.Template>
            
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <StackPanel
            Grid.Row="1"
            Grid.Column="1"
            Orientation="Vertical">
            <ToggleButton
                Padding="{DynamicResource WolvenKitLogMargin}"
                BorderThickness="1"
                Checked="AutoScroll_OnChecked"
                IsChecked="True"
                Unchecked="AutoScroll_OnUnchecked">
                <ToggleButton.Style>
                    <Style BasedOn="{StaticResource MahApps.Styles.Button.Chromeless}" TargetType="{x:Type ToggleButton}">
                        <Setter Property="Foreground" Value="Red" />
                        <Setter Property="ToolTip" Value="Disable autoscroll" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="Gray" />
                                <Setter Property="ToolTip" Value="Enable autoscroll" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>

                <templates:IconTemplateView
                    IconPack="MaterialDesign"
                    Kind="Repeat"
                    Size="{DynamicResource WolvenKitSmallIconSize}" />
            </ToggleButton>

            <Button
                Padding="{DynamicResource WolvenKitLogMargin}"
                BorderThickness="1"
                Click="ScrollToBottom_OnClick"
                Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                ToolTip="Scroll to bottom">
                <templates:IconTemplateView
                    IconPack="MaterialDesign"
                    Kind="VerticalAlignBottom"
                    Size="{DynamicResource WolvenKitSmallIconSize}"
                    Foreground="White" />
            </Button>

            <Button
                Padding="{DynamicResource WolvenKitLogMargin}"
                BorderThickness="1"
                Click="OpenLogFolder_Click"
                Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                ToolTip="Open log folder">
                <templates:IconTemplateView
                    IconPack="Codicons"
                    Kind="FolderOpened"
                    Size="{DynamicResource WolvenKitSmallIconSize}"
                    Foreground="White" />
            </Button>

            <Button
                Padding="{DynamicResource WolvenKitLogMargin}"
                BorderThickness="1"
                Click="ClearAll_Click"
                Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                ToolTip="Clear log">
                <templates:IconTemplateView
                    IconPack="Codicons"
                    Kind="ClearAll"
                    Size="{DynamicResource WolvenKitSmallIconSize}"
                    Foreground="White" />
            </Button>
        </StackPanel>
    </Grid>
</reactiveUi:ReactiveUserControl>
