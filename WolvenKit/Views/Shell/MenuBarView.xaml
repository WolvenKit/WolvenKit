<reactiveUi:ReactiveUserControl
    x:Class="WolvenKit.Views.Shell.MenuBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:others="clr-namespace:WolvenKit.Views.Others"
    xmlns:reactiveUi="http://reactiveui.net"
    xmlns:shared="clr-namespace:Syncfusion.Windows.Shared;assembly=Syncfusion.Shared.WPF"
    xmlns:shell="clr-namespace:WolvenKit.App.ViewModels.Shell;assembly=WolvenKit.App"
    xmlns:local="clr-namespace:WolvenKit.Views.Templates"
    x:TypeArguments="shell:MenuBarViewModel"
    mc:Ignorable="d">

    <!--  Resources  -->
    <UserControl.Resources>
        <ResourceDictionary>
            <shared:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

            <Style TargetType="{x:Type local:IconTemplateView}">
                <Setter Property="Opacity" Value="1.0" />

                <Style.Triggers>
                    <DataTrigger Binding="{Binding Path=IsEnabled, RelativeSource={RelativeSource AncestorType={x:Type MenuItem}}}"
                                 Value="False">
                        <Setter Property="Opacity" Value="0.5" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--  Main Grid  -->
    <Grid>
        <others:ScriptableMenu Background="Transparent" ScriptingName="MenuBarMain">
            <!--  Home  -->
            <MenuItem
                x:Name="HomeButton"
                Margin="1,0"
                Padding="12,5"
                Header="HOME" />

            <!--  File  -->
            <MenuItem Header="File"
                      FontSize="{DynamicResource WolvenKitSubTitleFontSize}"
                      Padding="{DynamicResource WolvenKitMarginHorizontal}">
                <MenuItem
                    x:Name="MenuItemNewFile"
                    Header="New File"
                    ToolTip="New File"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="NewFile"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitYellow}" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="Import"
                    Header="Import"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Empty"
                            Size="{DynamicResource WolvenKitTinyIconSize}" />
                    </MenuItem.Icon>

                    <MenuItem
                        x:Name="MenuItemImportArchive"
                        Header="Import .archive"
                        ToolTip="Import an .archive file for analysis"
                        Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                        <MenuItem.Icon>
                            <local:IconTemplateView
                                IconPack="Material"
                                Kind="ArchivePlusOutline"
                                Size="{DynamicResource WolvenKitTinyIconSize}"
                                Foreground="{StaticResource WolvenKitTan}" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem 
                        x:Name="ToolbarImportEntitySpawnerButton"
                        Header="Import entity spawner .json"
                        Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                        <MenuItem.Icon>
                            <local:IconTemplateView
                                IconPack="Material"
                                Kind="TextBoxPlusOutline"
                                Size="{DynamicResource WolvenKitTinyIconSize}"
                                Foreground="{StaticResource WolvenKitCyan}" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <MenuItem
                    x:Name="MenuItemSave"
                    Header="Save"
                    ToolTip="Save File"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="Save"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitCyan}" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="MenuItemSaveAs"
                    Header="Save As"
                    ToolTip="Save File"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="SaveAs"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitCyan}" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="MenuItemSaveAll"
                    Header="Save All"
                    ToolTip="Save All Files"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="SaveAll"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitCyan}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem
                    x:Name="MenuItemNewProject"
                    Header="New Project"
                    ToolTip="Create new WolvenKit mod project"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="NewFolder"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitTan}" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="MenuItemOpenProject"
                    Header="Open Project"
                    ToolTip="Open existing WolvenKit mod project"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="FolderOpened"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitTan}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!--  Project  -->
            <MenuItem Header="Project"
                      FontSize="{DynamicResource WolvenKitSubTitleFontSize}"
                      Padding="{DynamicResource WolvenKitMarginHorizontal}">
                <MenuItem
                    x:Name="ToolbarProjectSettingsButton"
                    Header="Project Configuration"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="SettingsGear"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="White" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem
                    x:Name="ToolbarProjectScanFilepathsButton"
                    Header="Scan project for broken file references"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="Search"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="White" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="ToolbarProjectFindUnusedFilesButton"
                    Header="Scan for unused project files"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="Search"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="White" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="ToolbarProjectRunFileValidationButton"
                    Header="Run File Validation on the entire project"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="PlayCircle"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="White" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!--  Build  -->
            <MenuItem Header="Build"
                      FontSize="{DynamicResource WolvenKitSubTitleFontSize}"
                      Padding="{DynamicResource WolvenKitMarginHorizontal}">
                <!--  Pack  -->
                <MenuItem
                    x:Name="MenuItemPack"
                    Header="Pack Project"
                    ToolTip="Pack mod and create zip file"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Material"
                            Kind="ArchiveCheckOutline"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitPurple}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Pack as REDmod  -->
                <MenuItem
                    x:Name="MenuItemPackRedmod"
                    Header="Pack as REDmod"
                    ToolTip="Pack as REDmod and create zip file"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}"
                    Visibility="{Binding EnableRedmodCommands, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Material"
                            Kind="ArchiveCheckOutline"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitPurple}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Install  -->
                <MenuItem
                    x:Name="MenuItemPackInstallProject"
                    Header="Install"
                    ToolTip="Pack mod &amp; install to game"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Material"
                            Kind="ArchiveSyncOutline"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitPurple}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Install as REDmod  -->
                <MenuItem
                    x:Name="MenuItemPackInstallRedmodProject"
                    Header="Install as REDmod"
                    ToolTip="Pack as REDmod &amp; install to game"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}"
                    Visibility="{Binding EnableRedmodCommands, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Material"
                            Kind="ArchiveSyncOutline"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitPurple}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Install & Launch Game  -->
                <MenuItem
                    x:Name="ToolbarPackInstallLaunchButton"
                    Header="Install &amp; Launch Game"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="RunAll"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitYellow}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Install as REDmod & Launch Game  -->
                <MenuItem
                    x:Name="ToolbarPackInstallRedmodLaunchButton"
                    Header="Install as REDmod &amp; Launch Game"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}"
                    Visibility="{Binding EnableRedmodCommands, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="RunAll"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitYellow}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Clean All  -->
                <MenuItem
                    x:Name="MenuItemClean"
                    Header="Clean All"
                    ToolTip="Clean project's packed directory completely"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Material"
                            Kind="DeleteOutline"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitRed}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Hot Reload  -->
                <MenuItem
                    x:Name="MenuItemHotInstallProject"
                    Header="Hot Reload"
                    ToolTip="Pack mod &amp; install directly to hot directory"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Material"
                            Kind="Fire"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{DynamicResource WolvenKitRed}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Launch Profiles  -->
                <MenuItem
                    x:Name="MenuItemLaunchProfiles"
                    Header="Launch Profiles"
                    ToolTip="Open launch profile settings"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="SettingsGear"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="White" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!--  View  -->
            <MenuItem Header="View"
                      FontSize="{DynamicResource WolvenKitSubTitleFontSize}"
                      Padding="{DynamicResource WolvenKitMarginHorizontal}">
                <MenuItem
                    x:Name="ProjectExplorerCheckbox"
                    Header="Project Explorer"
                    IsCheckable="True"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}" />

                <MenuItem
                    x:Name="AssetBrowserCheckbox"
                    Header="Asset Browser"
                    IsCheckable="True"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}" />

                <MenuItem
                    x:Name="TweakBrowserCheckbox"
                    Header="Tweak Browser"
                    IsCheckable="True"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}" />

                <MenuItem
                    x:Name="LocKeyBrowserCheckbox"
                    Header="LocKey Browser"
                    IsCheckable="True"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}" />

                <MenuItem
                    x:Name="PropertiesCheckbox"
                    Header="Properties"
                    IsCheckable="True"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}" />

                <MenuItem
                    x:Name="LogCheckbox"
                    Header="Log"
                    IsCheckable="True"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}" />

                <Separator />

                <MenuItem
                    Header="Show File Preview"
                    IsCheckable="True"
                    IsChecked="{Binding SettingsManager.ShowFilePreview, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="Toggle interactive file preview for improved performance"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}" />
                <!-- <MenuItem
                    x:Name="toolbarLabels"
                    Header="Show Toolbar Labels"
                    IsCheckable="True"
                    IsChecked="True"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}" />-->

                <Separator />

                <MenuItem
                    Click="SaveLayoutToProject"
                    Header="Save Layout to Project"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="Save"
                            Size="{DynamicResource WolvenKitTinyIconSize}" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    Click="SetLayoutToDefault"
                    Header="Reset Layout"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="MaterialDesign"
                            Kind="Refresh"
                            Size="{DynamicResource WolvenKitTinyIconSize}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!--  Tools  -->
            <MenuItem Header="Tools"
                      FontSize="{DynamicResource WolvenKitSubTitleFontSize}"
                      Padding="{DynamicResource WolvenKitMarginHorizontal}">
                <MenuItem
                    Click="GenerateMaterialRepoButton_Click"
                    Header="Depot Generator"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="ForkAwesome"
                            Kind="List"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitTan}" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="MenuItemShowSoundModdingTool"
                    Header="Sound Modding Tool"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="ForkAwesome"
                            Kind="VolumeUp"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitCyan}" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="MenuItemShowScriptManager"
                    Header="Script Manager"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Unicons"
                            Kind="JavaScript"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitPurple}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem
                    x:Name="MenuItemShowTextureImporter"
                    Header="Import Tool"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Unicons"
                            Kind="Import"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitYellow}" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="MenuItemShowTextureExporter"
                    Header="Export Tool"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Unicons"
                            Kind="Export"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitYellow}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem
                    x:Name="MenuItemShowHashTool"
                    Header="Hash Tool"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Bootstrap"
                            Kind="Hash"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitYellow}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem
                    x:Name="ToolbarSettingsButton"
                    Header="Settings"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="Settings"
                            Size="{DynamicResource WolvenKitTinyIconSize}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!--  Game  -->
            <MenuItem Header="Game"
                      FontSize="{DynamicResource WolvenKitSubTitleFontSize}"
                      Padding="{DynamicResource WolvenKitMarginHorizontal}">
                <MenuItem
                    x:Name="ToolbarLaunchButton"
                    CommandParameter="0"
                    Header="Launch Game"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="Play"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitYellow}" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="ToolbarLaunchSteamButton"
                    CommandParameter="1"
                    Header="Launch Game with Steam"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Empty"
                            Size="{DynamicResource WolvenKitTinyIconSize}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem
                    x:Name="MenuItemOpenGameFolder"
                    Header="Open Game Folder"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="FolderOpened"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitTan}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!--  Extensions  -->
            <MenuItem Header="Extensions"
                      FontSize="{DynamicResource WolvenKitSubTitleFontSize}"
                      Padding="{DynamicResource WolvenKitMarginHorizontal}">
                <MenuItem
                    x:Name="MenuItemShowPluginTool"
                    Header="Plugin Manager"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="Extensions"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitCyan}" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="MenuItemShowModsView"
                    Header="Mod Manager"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="Package"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitYellow}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem
                    x:Name="MenuItemCyberpunkBlenderAddonLink"
                    Header="Cyberpunk Blender Add-on"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="LinkExternal"
                            Size="{DynamicResource WolvenKitTinyIconSize}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!--  Help  -->
            <MenuItem Header="Help"
                      FontSize="{DynamicResource WolvenKitSubTitleFontSize}"
                      Padding="{DynamicResource WolvenKitMarginHorizontal}">
                <MenuItem
                    x:Name="MenuItemWolvenKitSetupLink"
                    Header="Setting up WolvenKit"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="LinkExternal"
                            Size="{DynamicResource WolvenKitTinyIconSize}" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="MenuItemWolvenKitCreatingAModLink"
                    Header="Creating a Mod"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="LinkExternal"
                            Size="{DynamicResource WolvenKitTinyIconSize}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem
                    x:Name="MenuItemDiscordInvitationLink"
                    Header="Discord Invitation"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="LinkExternal"
                            Size="{DynamicResource WolvenKitTinyIconSize}" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="MenuItemAboutWolvenKitLink"
                    Header="About WolvenKit"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="LinkExternal"
                            Size="{DynamicResource WolvenKitTinyIconSize}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem
                    x:Name="ToolbarOpenLogsButton"
                    Header="Open Logs Folder"
                    Margin="{DynamicResource WolvenKitMenuBarItemMarginHorizontal}">
                    <MenuItem.Icon>
                        <local:IconTemplateView
                            IconPack="Codicons"
                            Kind="FolderOpened"
                            Size="{DynamicResource WolvenKitTinyIconSize}"
                            Foreground="{StaticResource WolvenKitYellow}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </others:ScriptableMenu>
    </Grid>
</reactiveUi:ReactiveUserControl>
