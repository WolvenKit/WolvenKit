        Help="WizardControl_OnHelpButtonClicked"
        CancelButtonCancelsWindow="True"
        FinishButtonClosesWindow="True"
        CancelVisible="True"
        HelpVisible="True"
        Finish="WizardControl_OnFinish">

        <syncfusion:WizardPage
            Name="InitialConfigPage"
            Title="Configure your NPV"
            BannerBackground="{DynamicResource BackgroundBrush}"
            FinishVisibility="Collapsed"
            NextVisibility="Visible"
            BackVisibility="Collapsed"
            PreviewKeyDown="WizardPage_PreviewKeyDown"
            Description="Enter the numeric values from character creator (check your apartment's mirror)."
            NextPage="{Binding ElementName=ComponentsPage}">

            <Grid Margin="{DynamicResource WolvenKitMarginHorizontal}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{DynamicResource WolvenKitDialogLabelColumnWidth}" />
                    <ColumnDefinition Width="{DynamicResource WolvenKitNewFileIconWidth}" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                </Grid.RowDefinitions>


                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="{DynamicResource WolvenKitMarginBottom}">
                    <Run Text="If you can't see the character creator numbers, install AppearanceChangeUnlocker" />
                    <Hyperlink
                        Style="{StaticResource LinkStyle}"
                        NavigateUri="https://www.nexusmods.com/cyberpunk2077/mods/3850"
                        RequestNavigate="Hyperlink_RequestNavigate">
                        from Nexus
                    </Hyperlink>
                </TextBlock>

                <!-- Name -->
                <Label
                    Grid.Row="2"
                    Grid.Column="0">
                    NPC's Name
                </Label>
                <TextBox
                    Name="TextBoxName"
                    Grid.Row="2"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Margin="{DynamicResource WolvenKitMarginBottom}">
                    <TextBox.Text>
                        <Binding
                            Path="Name"
                            UpdateSourceTrigger="PropertyChanged" />
                    </TextBox.Text>
                </TextBox>

                <Label
                    Grid.Row="4"
                    Grid.Column="0">
                    Folder
                </Label>

                <!-- relative path (project folder) -->
                <editors:FilterableDropdownMenu
                    x:Name="FilterableDropdownMenu"
                    Grid.Row="4"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Label="Target Folder:"
                    Options="{Binding ProjectFolders,
                                      UpdateSourceTrigger=PropertyChanged}"
                    SelectedOption="{Binding DestFolderPath,
                                             Mode=TwoWay}"
                    IsInline="True" />

                <TextBox
                    x:Name="TextBoxFilePath"
                    Grid.Row="6"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Margin="{StaticResource WolvenKitMarginTinyVertical}"
                    helpers:TextBoxBehavior.FocusGainedSelectAll="True"
                    KeyboardNavigation.TabIndex="-1">

                    <TextBox.Text>
                        <Binding
                            Path="DestFolderPath"
                            UpdateSourceTrigger="PropertyChanged" />
                    </TextBox.Text>
                </TextBox>


                <!-- Body Gender -->
                <Label
                    Grid.Row="8"
                    Grid.Column="0">
                    Body Gender
                </Label>

                <ComboBox
                    Name="ComboboxBodyGender"
                    Grid.Row="8"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Width="{DynamicResource WolvenkitControlMinWidth}"
                    Margin="{DynamicResource WolvenKitMarginVertical}"
                    HorizontalAlignment="Left"
                    ItemsSource="{StaticResource BodyGenderListBoxItems}"
                    SelectedItem="{Binding BodyGender}" />

