                    Grid.Row="14"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Width="{DynamicResource WolvenkitControlMinWidth}"
                    Margin="{DynamicResource WolvenKitMarginBottom}"
                    HorizontalAlignment="Left"
                    ItemsSource="{StaticResource BlemishListBoxItems}"
                    SelectedIndex="{Binding Blemishes}" />


                <!-- Beard -->
                <Label
                    Grid.Row="16"
                    Grid.Column="0"
                    Visibility="{Binding Path=BodyGenderMale,
                                         Converter={StaticResource BooleanToVisibilityConverter}}">
                    Beard
                </Label>
                <ComboBox
                    Name="ComboboxBeard"
                    Grid.Row="16"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Width="{DynamicResource WolvenkitControlMinWidth}"
                    Margin="{DynamicResource WolvenKitMarginBottom}"
                    HorizontalAlignment="Left"
                    Visibility="{Binding Path=BodyGenderMale,
                                         Converter={StaticResource BooleanToVisibilityConverter}}"
                    ItemsSource="{StaticResource BeardListBoxItems}"
                    SelectedIndex="{Binding Beard}" />

                <!-- Beard Style -->
                <Label
                    Grid.Row="18"
                    Grid.Column="0"
                    Visibility="{Binding Path=BodyGenderMale,
                                         Converter={StaticResource BooleanToVisibilityConverter}}">
                    Beard Style
                </Label>
                <ComboBox
                    Name="ComboboxBeardStyle"
                    Grid.Row="18"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Width="{DynamicResource WolvenkitControlMinWidth}"
                    Margin="{DynamicResource WolvenKitMarginBottom}"
                    HorizontalAlignment="Left"
                    Visibility="{Binding Path=BodyGenderMale,
                                         Converter={StaticResource BooleanToVisibilityConverter}}"
                    ItemsSource="{StaticResource BeardStyleListBoxItems}"
                    SelectedIndex="{Binding BeardStyle}" />


            </Grid>
        </syncfusion:WizardPage>

    </syncfusion:WizardControl>
</Window>
