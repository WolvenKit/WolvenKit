                    ItemsSource="{StaticResource ShapekeyListBoxItems}"
                    SelectedIndex="{Binding Ears}" />
            </Grid>
        </syncfusion:WizardPage>

        <syncfusion:WizardPage
            Name="ComponentsPage"
            Title="Pick your components"
            Height="Auto"
            FinishVisibility="Visible"
            NextVisible="False"
            PreviewKeyDown="WizardPage_PreviewKeyDown"
