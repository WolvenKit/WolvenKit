<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Nullable>disable</Nullable>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <IsPackable>false</IsPackable>
    <Platforms>x64</Platforms>
    <TargetFramework>net8.0-windows10.0.17763</TargetFramework>
    <!-- UI tests launch WolvenKit.exe as an external process via FlaUI and require
         the app to be built and published separately (or pointed to via WOLVENKIT_EXE). -->
    <RootNamespace>WolvenKit.UITests</RootNamespace>
  </PropertyGroup>

    <ItemGroup Condition="'$(OS)' == 'Windows_NT'">
        <ProjectReference Include="..\..\WolvenKit\WolvenKit.csproj"
                          ReferenceOutputAssembly="false"
                          SkipGetTargetFrameworkProperties="true" />
    </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FlaUI.Core" />
    <PackageReference Include="FlaUI.UIA3" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="MSTest.TestAdapter" />
    <PackageReference Include="MSTest.TestFramework" />
    <PackageReference Include="coverlet.collector">
        <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>
